#!/bin/sh
# rc2runit — wrap a FreeBSD rc.d script as a runit service directory.
#
# One job: generate /service/<name>/{run,log/run} for a legacy rc.d
# service, per the migration section of DOCS/RUNIT.MD. The wrapper is
# transitional, not true supervision: the legacy script forks, so the run
# script starts it and polls `onestatus`, exiting (and letting runit act)
# when the service dies.
#
# usage: rc2runit [-r rcdir] [-s servicedir] [-l logbase] name
#
#   -r rcdir       where rc.d scripts live       (default: /etc/rc.d)
#   -s servicedir  where runit services live     (default: /service)
#   -l logbase     where svlogd logs go          (default: /var/log/sunshine)
#
# Exit codes: 0 ok, 1 generation error, 2 usage error.

set -eu

usage() {
    echo "usage: rc2runit [-r rcdir] [-s servicedir] [-l logbase] name" >&2
    exit 2
}

rcdir="/etc/rc.d"
servicedir="/service"
logbase="/var/log/sunshine"

while getopts "r:s:l:" opt; do
    case "$opt" in
        r) rcdir="$OPTARG" ;;
        s) servicedir="$OPTARG" ;;
        l) logbase="$OPTARG" ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

[ $# -eq 1 ] || usage
name="$1"

# Same naming rule as sunconfig: lowercase, starts with a letter, <= 32.
case "$name" in
    *[!a-z0-9_-]*|"")
        echo "rc2runit: invalid service name '$name'" >&2; exit 1 ;;
esac
case "$name" in
    [!a-z]*)
        echo "rc2runit: service name '$name' must start with a lowercase letter" >&2
        exit 1 ;;
esac
if [ "${#name}" -gt 32 ]; then
    echo "rc2runit: service name '$name' longer than 32 characters" >&2
    exit 1
fi

rcscript="$rcdir/$name"
if [ ! -f "$rcscript" ]; then
    echo "rc2runit: $rcscript does not exist" >&2
    exit 1
fi
if [ ! -x "$rcscript" ]; then
    echo "rc2runit: $rcscript is not executable" >&2
    exit 1
fi

svc="$servicedir/$name"
if [ -e "$svc" ]; then
    echo "rc2runit: $svc already exists; refusing to overwrite" >&2
    exit 1
fi

mkdir -p "$svc/log"

cat > "$svc/run" <<EOF
#!/bin/sh
# Generated by rc2runit -- transitional wrapper around $rcscript.
# Not true supervision: the legacy script forks; start it and poll.
exec 2>&1
rc="$rcscript"
[ -x "\$rc" ] || { echo "rc2runit: \$rc is not executable"; exit 1; }
"\$rc" onestart || exit 1
trap '"\$rc" onestop; exit 0' TERM INT
while "\$rc" onestatus >/dev/null 2>&1; do
    sleep 5 &
    wait \$!
done
echo "rc2runit: $name is no longer running"
exit 1
EOF

cat > "$svc/log/run" <<EOF
#!/bin/sh
# Generated by rc2runit -- DO NOT EDIT.
exec svlogd -tt $logbase/$name
EOF

chmod 0755 "$svc/run" "$svc/log/run"

# Verify what we just claimed to create (DOCS/ENGINEERING.MD 3.6).
for f in "$svc/run" "$svc/log/run"; do
    if [ ! -x "$f" ]; then
        echo "rc2runit: verification failed: $f is not executable" >&2
        exit 1
    fi
done

echo "rc2runit: created $svc"
